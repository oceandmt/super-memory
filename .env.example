# Environment variables for Super Memory deployment.
# Copy to .env and fill in your values:
#   cp .env.example .env

# ─── Core ───────────────────────────────────────────────────────────────────
# Path to OpenClaw workspace root (canonical markdown lives here)
SUPER_MEMORY_WORKSPACE_ROOT=/home/oceandmt/.openclaw/workspace

# SQLite database path (relative to workspace_root, or absolute)
SUPER_MEMORY_SQLITE_PATH=data/super-memory.sqlite3

# ─── API Server ─────────────────────────────────────────────────────────────
# API_HOST=127.0.0.1
# API_PORT=8765

# Bearer token for REST API auth (empty = no auth — dev only!)
# API_TOKEN=

# ─── Database Backend ───────────────────────────────────────────────────────
# Options: sqlite (default) | postgres
# SUPER_MEMORY_DB_BACKEND=sqlite

# PostgreSQL (only if db_backend=postgres)
# POSTGRES_URL=postgresql://user:pass@localhost:5432/super_memory

# ─── Advanced ───────────────────────────────────────────────────────────────
# LLM embedding mode: optional|disabled|external
# SUPER_MEMORY_EMBED_MODE=optional

# Enable vector embedding recall (requires sqlite-vec)
# SUPER_MEMORY_VECTOR_ENABLED=false

# ─── Observability ──────────────────────────────────────────────────────────
# SUPER_MEMORY_DEBUG=0
# SUPER_MEMORY_LOG_LEVEL=INFO
